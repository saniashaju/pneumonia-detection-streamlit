import speech_recognition as sr
import pyttsx3

# Initialize the speech recognition and TTS engine
recognizer = sr.Recognizer()
tts_engine = pyttsx3.init()

def speak(text):
    """Convert text to speech"""
    tts_engine.say(text)
    tts_engine.runAndWait()

def listen():
    """Listen for a voice input and convert it to text"""
    with sr.Microphone() as source:
        print("Listening... Speak now.")
        recognizer.adjust_for_ambient_noise(source)
        audio = recognizer.listen(source)

        try:
            print("Recognizing...")
            query = recognizer.recognize_google(audio)
            print(f"You said: {query}")
            return query.lower()
        except sr.UnknownValueError:
            print("Sorry, I couldn't understand that.")
            speak("Sorry, I couldn't understand that.")
        except sr.RequestError:
            print("Network error.")
            speak("Sorry, there's a network issue.")
        return ""

def process_command(command):
    """Respond to specific voice commands"""
    if "your name" in command:
        response = "I'm bengali babu."
        print("Assistant:", response)
        speak(response)
    elif "how are you" in command:
        response = "I'm doing great, thank you!"
        print("Assistant:", response)
        speak(response)
    elif "gay" in command:
        response = "everyone knows Alen is gay."
        print("Assistant:", response)
        speak(response)        
    elif "best friend" in command:
        response = "Babu is your bestfriend."
        print("Assistant:", response)
        speak(response) 
    else:
        response = "I'm not sure how to respond to that."
        print("Assistant:", response)
        speak(response)
    
# Main loop or one-time run
if _name_ == "_main_":
    while True:
        voice_input = listen()
        if voice_input:
            process_command(voice_input)